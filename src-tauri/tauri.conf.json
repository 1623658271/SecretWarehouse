{
  "$schema": "https://raw.githubusercontent.com/nicoverbruggen/tauri-settings/main/src/schema.json",
  "productName": "SecretWarehouse",
  "version": "0.1.0",
  "identifier": "com.secretwarehouse.app",
  "build": {
    "frontendDist": "../dist/env",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SecretWarehouse - 安全密码管理器",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "maximized": true,
        "resizable": true,
        "decorations": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/SecretWarehouse.ico",
      "icons/SecretWarehouse.png",
      "icons/icon.icns"
    ]
  }
}
